APP_NAME="IOB CTS National Grid"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cts.iob.in

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

#-------------------------------------------------------------------
# Oracle Database (Primary DC - Chennai)
#-------------------------------------------------------------------
DB_CONNECTION=oracle
DB_HOST=
DB_PORT=1521
DB_DATABASE=CTSDB
DB_USERNAME=cts_app
DB_PASSWORD=

# Oracle DR (Hyderabad) - used during failover
DB_DR_HOST=
DB_DR_PORT=1521
DB_DR_DATABASE=CTSDB
DB_DR_USERNAME=cts_app
DB_DR_PASSWORD=

# Oracle Legacy (for migration only)
ORACLE_LEGACY_HOST=
ORACLE_LEGACY_DATABASE=LEGACY_CTS

#-------------------------------------------------------------------
# Redis (Session, Cache, Queue)
#-------------------------------------------------------------------
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_LIFETIME=15

#-------------------------------------------------------------------
# CTS Grid Infrastructure
#-------------------------------------------------------------------
CTS_DC_HOST=
CTS_DR_HOST=
CTS_UAT_HOST=

#-------------------------------------------------------------------
# NPCI Integration
#-------------------------------------------------------------------
NPCI_BASE_URL=https://npci-cpps.npci.org.in
NPCI_CLIENT_ID=
NPCI_CLIENT_SECRET=

#-------------------------------------------------------------------
# CHI / DEM Interface
#-------------------------------------------------------------------
CHI_DEM_HOST=
CHI_DEM_PORT=8443
CHI_DEM_CERT_PATH=/certs/chi-dem/client.crt
CHI_DEM_KEY_PATH=/certs/chi-dem/client.key

#-------------------------------------------------------------------
# Finacle CBS Integration
#-------------------------------------------------------------------
FINACLE_HOST=
FINACLE_PORT=8080
FINACLE_API_KEY=
FINACLE_VERSION=10.x

#-------------------------------------------------------------------
# PKI / HSM
#-------------------------------------------------------------------
HSM_HOST=
HSM_PORT=1792
PKI_CERT_STORE=/certs/cts
PKI_CA_CERT=/certs/cts/ca.pem
PKI_KEY_PASSPHRASE=

#-------------------------------------------------------------------
# AI / OCR Engine
#-------------------------------------------------------------------
AI_OCR_ENGINE_URL=http://localhost:8081
AI_ENGINE_SECRET=

#-------------------------------------------------------------------
# Image Storage
#-------------------------------------------------------------------
IMAGE_STORAGE_DRIVER=local
FILESYSTEM_DISK=local

# AWS S3 (optional for archive tier)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=iob-cts-archive
AWS_URL=

#-------------------------------------------------------------------
# Notifications
#-------------------------------------------------------------------
SMS_GATEWAY_URL=
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=cts@iob.in
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=cts@iob.in
MAIL_FROM_NAME="IOB CTS System"
IT_TEAM_EMAILS=it.cts@iob.in,it.head@iob.in

#-------------------------------------------------------------------
# LDAP / AD Authentication
#-------------------------------------------------------------------
LDAP_ENABLED=true
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN="dc=iob,dc=in"

#-------------------------------------------------------------------
# CTS Processing Thresholds
#-------------------------------------------------------------------
CTS_HIGH_VALUE_THRESHOLD=500000
CTS_DUAL_VERIFY_THRESHOLD=100000
